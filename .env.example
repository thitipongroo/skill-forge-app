# >>> Rename this file to .env  (cp env.example .env)  then fill in the values. <<<

# Postgres. The docker-compose.yml in this repo starts one that matches this URL.
DATABASE_URL="postgresql://forge:forge@localhost:5432/forge?schema=public"

# Auth.js session secret. Generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# Web Push (VAPID). Generate once with:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Protects the reminder cron endpoint (Authorization: Bearer <value>)
CRON_SECRET="change-me"

# AI coach (optional). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=""
